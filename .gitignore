# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# =============================================================================
# .gitignore — Java + Gradle + VSCode + Ubuntu
# =============================================================================


# =============================================================================
# JAVA
# =============================================================================

# Compiled class files
*.class

# Log files
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*


# =============================================================================
# GRADLE
# =============================================================================

# Gradle wrapper
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.properties

# Gradle cache & build outputs
.gradle/
**/build/
!src/**/build/

# Gradle local properties (may contain secrets/paths)
local.properties
gradle.properties.local

# Gradle Kotlin DSL caches
**/.kotlin/

# Avoid ignoring Gradle wrapper jar file
!gradle-wrapper.jar

# Gradle enterprise
.gradle-enterprise/

# Convention plugins build folder
buildSrc/build/


# =============================================================================
# VSCODE
# =============================================================================

.vscode/*

# Keep shared recommended extensions and settings
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# VSCode history plugin
.history/
*.vshistory

# VSCode test result files
.vscode-test/


# =============================================================================
# UBUNTU / LINUX
# =============================================================================

# Thumbnails
.thumbnails/
Thumbs.db

# Trash folder
.Trash-*/

# Desktop Services Store (cross-platform)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# KDE directory preferences
.directory

# Linux swap / temp files
*~
*.swp
*.swo
.nfs*

# Snap
.snap

# Core dumps
core


# =============================================================================
# MAVEN (bonus, por si lo usas junto a Gradle)
# =============================================================================

target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar


# =============================================================================
# IDEs ADICIONALES
# =============================================================================

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/


# =============================================================================
# SECRETOS Y CONFIGURACIÓN LOCAL
# =============================================================================

# Variables de entorno
.env
.env.*
!.env.example

# Archivos de configuración con credenciales
secrets.properties
application-local.properties
application-local.yml
**/src/main/resources/application-dev.properties
**/src/main/resources/application-dev.yml

# Keystores
*.jks
*.keystore
*.p12
*.pfx


# =============================================================================
# MISCELÁNEOS
# =============================================================================

# Archivos temporales del SO
*.tmp
*.temp
*.bak
*.orig
*.rej

# Reportes de cobertura
coverage/
*.lcov
jacoco.exec
jacoco/

# Archivos de documentación generada
docs/_build/
site/

# Node (si usas herramientas frontend en el proyecto)
node_modules/
npm-debug.log*
yarn-error.log*